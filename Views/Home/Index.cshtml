@{
    ViewData["Title"] = "Global Chat & Call";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header text-white" style="background-color: #075E54;">
                    <h5 class="mb-0">Charcha Chat</h5>
                </div>

                <div class="card-body" id="chatWindow" style="height: 300px; overflow-y: auto; background-color: #EFEAE2;">
                    <ul id="messagesList" class="list-unstyled mb-0 d-flex flex-column gap-2"></ul>
                </div>

                <div class="card-footer bg-light">
                    <div class="row g-2">
                        <div class="col-4">
                            <input type="text" id="userInput" class="form-control form-control-sm" placeholder="Your Name" />
                        </div>
                        <div class="col-5">
                            <input type="text" id="messageInput" class="form-control form-control-sm" placeholder="Message..." />
                        </div>
                        <div class="col-3 d-grid">
                            <button id="sendButton" class="btn btn-success btn-sm" style="background-color: #128C7E; border: none;" disabled>Send</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Video Call</h5>
                    <button id="startCallButton" class="btn btn-success btn-sm" disabled>Start Call</button>
                </div>
                <div class="card-body bg-black text-center position-relative" style="height: 300px;">
                    <video id="remoteVideo" autoplay playsinline style="width: 100%; height: 100%; object-fit: cover;"></video>
                    <video id="localVideo" autoplay muted playsinline style="width: 100px; position: absolute; bottom: 10px; right: 10px; border: 2px solid white; border-radius: 8px;"></video>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/chat.js"></script>
}